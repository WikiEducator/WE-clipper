{
  "manifest_version": 3,
  "name": "WE-clipper",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://wikieducator.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "WE-clipper@wikieducator.org",
      "update_url": "https://raw.githubusercontent.com/WikiEducator/WE-clipper/main/dev/updates.json",
      "data_collection_permissions": {
        "required": [
          "websiteContent"
        ]
      }
    }
  }
}

